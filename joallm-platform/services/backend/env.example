# Database
DATABASE_URL=postgresql://username:password@localhost:5432/joallm
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=joallm
DATABASE_USER=username
DATABASE_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# API Keys
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GROQ_API_KEY=gsk-your-groq-key-here
COHERE_API_KEY=your-cohere-api-key-here

# Creative AI (image generation for Acquisition Assets)
IDEOGRAM_API_KEY=your-ideogram-api-key
BFL_API_KEY=your-black-forest-labs-flux-key
# FLUX_API_KEY=  # optional alias for BFL_API_KEY

# Ollama (Local/Self-hosted LLMs)
OLLAMA_API_KEY=your-ollama-api-key-here
OLLAMA_BASE_URL=http://localhost:11434

# File Storage
# Options: 'local' (Railway Volume), 'cloudflare-r2', 'aws-s3'
# If R2 credentials not set, automatically falls back to local storage
STORAGE_PROVIDER=local
STORAGE_PATH=/app/data/uploads

# Cloudflare R2 (optional - only if using R2 instead of local)
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=joallm-documents

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Encryption (for sensitive data like user API keys)
# Generate a strong 32-byte key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-256-bit-encryption-key-here

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:5174

# Logging
LOG_LEVEL=info

# Google OAuth (for social login)
# GOOGLE_REDIRECT_URI must EXACTLY match an Authorized redirect URI in Google Cloud Console
# Production example:
#   GOOGLE_REDIRECT_URI=https://<your-backend-host>/api/auth/google/callback
#   FRONTEND_URL=https://platform.atrisi.org
#   CORS_ORIGIN=https://platform.atrisi.org,https://atrisi.org
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# API Key for service-to-service communication
API_KEY=your-api-key-for-service-auth-here


