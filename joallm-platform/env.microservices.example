# Microservices Environment Configuration

# Database
DATABASE_URL=postgresql://joallm:joallm_password@localhost:5432/joallm
POSTGRES_DB=joallm
POSTGRES_USER=joallm
POSTGRES_PASSWORD=joallm_password

# Redis
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Service API Keys
SERVICE_API_KEY=your-service-api-key

# LLM Provider API Keys
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GROQ_API_KEY=your-groq-api-key
COHERE_API_KEY=your-cohere-api-key

# Service URLs
AUTH_SERVICE_URL=http://localhost:3001
CHAT_SERVICE_URL=http://localhost:3002
RAG_SERVICE_URL=http://localhost:3003
FILE_SERVICE_URL=http://localhost:3004
API_GATEWAY_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
VITE_PLATFORM_URL=http://localhost:5173

# Google OAuth (auth login + workspace integrations)
# GOOGLE_WORKSPACE_REDIRECT_URI must be registered in Google Cloud Console
GOOGLE_WORKSPACE_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback

# Billing — Razorpay
# Key ID + Secret: from Razorpay Dashboard > Settings > API Keys
# When set, checkout creates a dynamic payment link with user_id in notes (required for webhook matching)
RAZORPAY_KEY_ID=rzp_live_replace-me
RAZORPAY_KEY_SECRET=replace-me
# Webhook secret: from Razorpay Dashboard > Settings > Webhooks
RAZORPAY_WEBHOOK_SECRET=replace-me
# Static fallback link (used only if KEY_ID/KEY_SECRET are not set — no auto tier upgrade)
RAZORPAY_PAYMENT_LINK_URL=https://rzp.io/rzp/replace-me
VITE_RAZORPAY_PAYMENT_LINK_URL=https://rzp.io/rzp/replace-me

# Event Bus
EVENT_BUS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX=1000
RATE_LIMIT_TIME_WINDOW=1 minute

# Circuit Breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60000
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# Load Balancing
LOAD_BALANCING_STRATEGY=round-robin

# Logging
LOG_LEVEL=info
NODE_ENV=development
