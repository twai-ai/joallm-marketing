# Backend image built from repo root (leave Railway Root Directory EMPTY).
# Dashboard:
#   Root Directory: (blank)
#   Builder: Dockerfile
#   Dockerfile path: Dockerfile.backend
# Or set service variable: RAILWAY_DOCKERFILE_PATH=Dockerfile.backend

FROM node:18-alpine AS builder

WORKDIR /app

RUN apk update && apk add --no-cache \
    python3 \
    make \
    curl \
    ffmpeg \
    && apk add --no-cache --virtual .build-deps \
    g++ \
    gcc \
    musl-dev

COPY joallm-platform/services/backend/package*.json ./

RUN npm install -g patch-package && \
    npm install --legacy-peer-deps

COPY joallm-platform/services/backend/ ./

RUN npm run build

RUN mkdir -p dist/database && \
    cp -r src/database/migrations dist/database/

RUN npm prune --production --legacy-peer-deps

FROM node:18-alpine AS production

WORKDIR /app

RUN apk update && apk add --no-cache \
    postgresql-client \
    curl \
    ffmpeg \
    && rm -rf /var/cache/apk/*

COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package*.json ./
COPY --from=builder /app/railway-start.sh ./
RUN chmod +x railway-start.sh

RUN addgroup -g 1001 -S nodejs && \
    adduser -S nodejs -u 1001 && \
    chown -R nodejs:nodejs /app

USER nodejs

EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
  CMD curl -f http://localhost:3001/api/health || exit 1

CMD ["./railway-start.sh"]
