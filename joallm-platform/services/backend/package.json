{
  "name": "joallm-backend",
  "version": "1.0.0",
  "description": "ATRISI Marketing Backend API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc && mkdir -p dist/database && cp -r src/database/migrations dist/database/",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "worker": "tsx src/worker.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:integration": "vitest run tests/integration",
    "test:integration:watch": "vitest watch tests/integration",
    "lint": "eslint src --ext .ts",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "RESET_DATABASE=true tsx src/database/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx scripts/seed-database.ts",
    "setup:models": "tsx scripts/setup-models.ts",
    "debug:env": "node -e \"console.log('Environment Variables:'); console.log('OPENAI_API_KEY:', process.env.OPENAI_API_KEY ? 'SET' : 'NOT SET'); console.log('GROQ_API_KEY:', process.env.GROQ_API_KEY ? 'SET' : 'NOT SET'); console.log('ANTHROPIC_API_KEY:', process.env.ANTHROPIC_API_KEY ? 'SET' : 'NOT SET'); console.log('COHERE_API_KEY:', process.env.COHERE_API_KEY ? 'SET' : 'NOT SET');\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/s3-request-presigner": "^3.1010.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.1.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.15.4",
    "cohere-ai": "^7.19.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.28.1",
    "google-auth-library": "^10.4.2",
    "groq-sdk": "^0.34.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "marked": "^14.0.4",
    "openai": "^4.67.3",
    "otplib": "^12.0.1",
    "pdf-parse": "^1.1.1",
    "pgvector": "^0.1.8",
    "pino-pretty": "^13.1.1",
    "postgres": "^3.4.4",
    "prom-client": "^15.1.0",
    "qrcode": "^1.5.3",
    "redis": "^4.6.14",
    "tsx": "^4.20.6",
    "winston": "^3.14.2",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.12",
    "@types/pdf-parse": "^1.1.4",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitest/coverage-v8": "^2.0.4",
    "drizzle-kit": "^0.24.2",
    "eslint": "^8.57.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
